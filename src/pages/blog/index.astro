---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog" description="Posts about web development, tools, and workflows">
  <section class="py-12">
    <h1 class="font-mono text-2xl sm:text-3xl font-bold mb-8" style={`color: var(--text-heading);`}>
      Blog
    </h1>
    {posts.length > 0 ? (
      <div>
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.id}
          />
        ))}
      </div>
    ) : (
      <p style={`color: var(--text-muted);`}>No posts yet.</p>
    )}
  </section>
</BaseLayout>
