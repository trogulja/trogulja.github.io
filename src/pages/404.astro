---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="Page not found">
  <section class="py-24 text-center">
    <h1 class="font-mono text-6xl sm:text-8xl font-bold mb-4 glow" style={`color: var(--text-heading);`}>
      <span class="glitch" data-text="404">404</span>
    </h1>
    <p class="font-mono text-lg mb-2" style={`color: var(--text-muted);`}>
      $ cat page.html
    </p>
    <p class="font-mono mb-8" style={`color: var(--text-primary);`}>
      cat: page.html: No such file or directory
    </p>
    <a
      href="/"
      class="inline-block font-mono text-sm px-4 py-2 rounded border hover:underline transition-colors"
      style={`color: var(--text-heading); border-color: var(--border-color); background-color: var(--bg-card);`}
    >
      cd ~
    </a>
  </section>
</BaseLayout>
