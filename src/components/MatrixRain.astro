---
// Subtle Matrix rain background effect.
// Canvas is created via vanilla JS and appended to <html> (not <body>),
// so Astro view transitions never touch it — no detach/reattach, no swap.
---

<script is:inline>
  (function () {
    // Guard: only initialize once across view transition navigations
    // (is:inline scripts re-run on every Astro navigation)
    if (window.__matrixRainInitialized) return;
    window.__matrixRainInitialized = true;

    function initMatrixRain() {
      // Reuse existing canvas or create a new one
      var canvas = document.getElementById('matrix-rain');
      if (!canvas) {
        canvas = document.createElement('canvas');
        canvas.id = 'matrix-rain';
        canvas.setAttribute('aria-hidden', 'true');
        canvas.style.cssText = 'position:fixed;inset:0;z-index:0;pointer-events:none;';
        document.documentElement.appendChild(canvas);
      }
      var ctx = canvas.getContext('2d');
      if (!ctx) return;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        canvas.style.display = 'none';
        return;
      }

      if (localStorage.getItem('matrix-rain') === 'off') {
        canvas.style.display = 'none';
        return;
      }

      // ── Tweak these ──────────────────────────────────────────
      var FONT_SIZE = 14;
      var FPS = 20;
      var SPAWN_CHANCE = 0.002;
      var TRAIL_LENGTH = 150;
      var FADE_SPEED = 0.001;
      var CHARS = 'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン0123456789ABCDEF<>/{}[];=+-*&^%$#@!';

      var HEAD_ALPHA_DARK = 0.20;   var HEAD_ALPHA_LIGHT = 0.40;
      var TRAIL_ALPHA_DARK = 0.08;  var TRAIL_ALPHA_LIGHT = 0.15;
      // ────────────────────────────────────────────────────────

      var charList = CHARS.split('');
      var columns;
      var headY, life, charMap;

      function randomChar() {
        return charList[Math.floor(Math.random() * charList.length)];
      }

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        var newCols = Math.floor(canvas.width / FONT_SIZE);
        var rows = Math.ceil(canvas.height / FONT_SIZE) + TRAIL_LENGTH;

        var oldHeadY = headY || [];
        var oldLife = life || [];
        var oldCharMap = charMap || [];

        headY = new Array(newCols);
        life = new Array(newCols);
        charMap = new Array(newCols);

        for (var i = 0; i < newCols; i++) {
          headY[i] = oldHeadY[i] != null ? oldHeadY[i] : -1;
          life[i] = oldLife[i] != null ? oldLife[i] : 0;
          if (oldCharMap[i]) {
            charMap[i] = oldCharMap[i];
            while (charMap[i].length < rows) charMap[i].push(randomChar());
          } else {
            charMap[i] = [];
            for (var r = 0; r < rows; r++) charMap[i].push(randomChar());
          }
        }
        columns = newCols;
      }

      resize();

      var lastWidth = window.innerWidth;
      function onResize() {
        var w = window.innerWidth;
        if (w === lastWidth) return;
        lastWidth = w;
        resize();
      }
      window.addEventListener('resize', onResize);

      function getThemeConfig() {
        var light = document.documentElement.getAttribute('data-theme') === 'light';
        return {
          rgb: light ? '22, 163, 74' : '74, 222, 128',
          headAlpha: light ? HEAD_ALPHA_LIGHT : HEAD_ALPHA_DARK,
          trailAlpha: light ? TRAIL_ALPHA_LIGHT : TRAIL_ALPHA_DARK,
        };
      }

      // Clean up if re-initializing (RainToggle restart)
      if (window.__matrixRainId) {
        cancelAnimationFrame(window.__matrixRainId);
        window.__matrixRainId = null;
      }

      // Pause/resume on tab switch
      function onVis() {
        if (document.hidden) {
          if (window.__matrixRainId) {
            cancelAnimationFrame(window.__matrixRainId);
            window.__matrixRainId = null;
          }
        } else if (localStorage.getItem('matrix-rain') !== 'off' && !window.__matrixRainId) {
          window.__matrixRainId = requestAnimationFrame(frame);
        }
      }
      if (window.__matrixVisHandler) {
        document.removeEventListener('visibilitychange', window.__matrixVisHandler);
      }
      window.__matrixVisHandler = onVis;
      document.addEventListener('visibilitychange', onVis);

      var lastTime = 0;
      var interval = 1000 / FPS;
      var maxRow = function () { return Math.ceil(canvas.height / FONT_SIZE); };

      function frame(timestamp) {
        window.__matrixRainId = requestAnimationFrame(frame);
        if (timestamp - lastTime < interval) return;
        lastTime = timestamp;

        var config = getThemeConfig();
        var rgb = config.rgb;
        var headAlpha = config.headAlpha;
        var trailAlpha = config.trailAlpha;

        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.font = FONT_SIZE + 'px monospace';

        for (var i = 0; i < columns; i++) {
          if (life[i] <= 0) {
            if (Math.random() < SPAWN_CHANCE) {
              life[i] = 1;
              headY[i] = 0;
              for (var r = 0; r < charMap[i].length; r++) {
                charMap[i][r] = randomChar();
              }
            }
            continue;
          }

          var head = headY[i];
          var rows = maxRow();

          for (var t = 0; t <= TRAIL_LENGTH; t++) {
            var row = head - t;
            if (row < 0 || row > rows + TRAIL_LENGTH) continue;

            var x = i * FONT_SIZE;
            var y = row * FONT_SIZE;
            var char = charMap[i][row % charMap[i].length];

            var alpha;
            if (t === 0) {
              alpha = headAlpha * life[i];
            } else {
              var trailFactor = 1 - (t / TRAIL_LENGTH);
              alpha = trailAlpha * trailFactor * life[i];
            }

            if (alpha < 0.005) continue;

            ctx.fillStyle = 'rgba(' + rgb + ', ' + alpha + ')';
            ctx.fillText(char, x, y);
          }

          headY[i]++;
          life[i] -= FADE_SPEED;

          if (head - TRAIL_LENGTH > rows) {
            life[i] = 0;
          }
        }
      }

      window.__matrixRainId = requestAnimationFrame(frame);
    }

    window.__matrixRainRestart = initMatrixRain;
    initMatrixRain();
  })();
</script>
