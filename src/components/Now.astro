---
// "Now" section — what I'm currently up to.
// Inspired by https://nownownow.com/about
// Update this whenever focus shifts.

const now = [
  {
    label: 'Attending',
    text: 'AI Engineer Europe in London (Apr 8-10) — catching up on the latest in AI infrastructure, tooling, and applied LLMs.',
  },
  {
    label: 'Building',
    text: 'AI developer tools at Productive — observability dashboards, trace triage, and internal tooling that helps the team ship faster.',
  },
  {
    label: 'Tinkering',
    text: 'A plugin marketplace for Claude Code — shareable skills and workflows for the whole engineering team.',
  },
  {
    label: 'Automating',
    text: 'Local dev environment orchestration with Docker and mise. Replacing the "it works on my machine" era.',
  },
  {
    label: 'Expanding',
    text: 'The Rust CLI toolbox — because four CLIs apparently wasn\'t enough. Now there\'s six.',
  },
];

const updated = '2026-04-06';
---

<section class="py-12 reveal">
  <h2 class="font-mono text-xl font-bold mb-6" style={`color: var(--text-heading);`}>
    ## Now
  </h2>
  <ul class="space-y-3">
    {now.map((item) => (
      <li class="flex gap-3 leading-relaxed" style={`color: var(--text-primary);`}>
        <span class="font-mono shrink-0" style={`color: var(--text-heading);`}>{`>`}</span>
        <span>
          <strong class="font-mono" style={`color: var(--text-heading);`}>{item.label}:</strong>{' '}
          {item.text}
        </span>
      </li>
    ))}
  </ul>
  <p class="mt-6 text-xs font-mono" style={`color: var(--text-muted);`}>
    Last updated: {updated}
  </p>
</section>
