---
// "Now" section — what I'm currently up to.
// Inspired by https://nownownow.com/about
// Update this whenever focus shifts.

const now = [
  {
    label: 'Building',
    text: 'Experiment observability for AI assistants at Productive — A/B testing infrastructure, trace analysis, and metrics that show which model changes actually move the needle.',
  },
  {
    label: 'Speaking',
    text: 'Preparing a talk for .debug 2026 (June 9–10, Zagreb) — submitted this week, details coming soon.',
  },
  {
    label: 'Crafting',
    text: 'A personal knowledge system for Claude Code — structured lore that replaces flat memory with layered, context-aware injection. Inspired by Karpathy\'s LLM wiki pattern.',
  },
  {
    label: 'Tinkering',
    text: 'A plugin marketplace for Claude Code — shareable skills and workflows for the whole engineering team.',
  },
  {
    label: 'Expanding',
    text: 'The Rust CLI toolbox — because four CLIs apparently wasn\'t enough. Now there\'s seven.',
  },
];

const updated = '2026-04-16';
---

<section class="py-12 reveal">
  <h2 class="font-mono text-xl font-bold mb-6" style={`color: var(--text-heading);`}>
    ## Now
  </h2>
  <ul class="space-y-3">
    {now.map((item) => (
      <li class="flex gap-3 leading-relaxed" style={`color: var(--text-primary);`}>
        <span class="font-mono shrink-0" style={`color: var(--text-heading);`}>{`>`}</span>
        <span>
          <strong class="font-mono" style={`color: var(--text-heading);`}>{item.label}:</strong>{' '}
          {item.text}
        </span>
      </li>
    ))}
  </ul>
  <p class="mt-6 text-xs font-mono" style={`color: var(--text-muted);`}>
    Last updated: {updated}
  </p>
</section>
